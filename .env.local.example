# Google Gemini AI Configuration (OpenAI-Compatible API)
# ======================================================
# Required for blog post generation and AI content features

# Get your API key from: https://aistudio.google.com/app/apikey
# 1. Go to the link above
# 2. Click "Create API Key"
# 3. Copy the generated key (starts with AIza)
# 4. Add it to .env.local (this file is excluded from git)

GEMINI_API_KEY=your_api_key_here


# Optional: Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_public_key
CLERK_SECRET_KEY=your_clerk_secret_key

# Optional: Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Email Service (Nodemailer)
EMAIL_FROM=your_email@example.com
EMAIL_APP_PASSWORD=your_app_password

# Optional: ImageKit CDN
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint

# Optional: Analytics and Tracking
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id
