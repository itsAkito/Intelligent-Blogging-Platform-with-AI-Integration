# =============================================================
# AiBlog Platform — Environment Variables
# =============================================================
# Copy this file to .env.local and fill in actual values.
# On Vercel, add these in Project Settings → Environment Variables.
# Do NOT set NODE_ENV manually — Vercel/Next.js handles it.
# =============================================================

# ----- App URL (REQUIRED for production) -----
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ----- Supabase (REQUIRED) -----
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ----- Clerk Authentication (REQUIRED) -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key

# ----- Admin Configuration (REQUIRED) -----
ADMIN_EMAIL=admin@yourdomain.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_admin_password
NEXT_PUBLIC_ADMIN_PASSWORD=your_secure_admin_password
ADMIN_SESSION_SECRET=generate_a_random_64_char_string
ADMIN_TOKEN=generate_a_random_token
ADMIN_DISPLAY_NAME=Admin

# ----- AI Providers (at least one REQUIRED) -----
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=your_openai_api_key
# GROQ_API_KEY=your_groq_api_key
# XAI_API_KEY=your_xai_api_key
# PERPLEXITY_API_KEY=your_perplexity_api_key
# CLIPDROP_API_KEY=your_clipdrop_api_key

# ----- ImageKit CDN (optional) -----
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint

# ----- SMTP / Email (optional — for OTP & newsletters) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=AiBlog <your_email@gmail.com>

# ----- Razorpay Payments (required for subscriptions) -----
RAZORPAY_KEY_ID=rzp_test_SZIoHft7ahfDEh
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_SZIoHft7ahfDEh

# ----- Cron & Security Tokens -----
# CRON_SECRET — used to authenticate Vercel cron to /api/cron/publish-scheduled
CRON_SECRET=generate_a_random_32_char_string
# PREVIEW_SECRET — used to sign draft preview URLs (HMAC-SHA256)
PREVIEW_SECRET=generate_a_random_64_char_string

# ----- External APIs (optional) -----
# NEWSDATA_API_KEY=your_newsdata_api_key
# ADZUNA_APP_ID=your_adzuna_app_id
# ADZUNA_APP_KEY=your_adzuna_app_key

# ----- Dev/Debug (do NOT set in production) -----
# OTP_DEV_TEST_MODE=true
